# Database (local Docker Postgres)
DATABASE_URL=postgresql://formforge:formforge@localhost:5432/formforge

# Production — Neon FormForge (use pooler hostname, sslmode=require)
# DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxx-pooler.c-4.us-east-2.aws.neon.tech/neondb?sslmode=require

# Redis (local Docker)
REDIS_URL=redis://localhost:6379

# Production rate limiting — shared Upstash DB with QuickPad is OK (use REDIS_KEY_PREFIX)
# UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
# UPSTASH_REDIS_REST_TOKEN=
# REDIS_KEY_PREFIX=formforge:

# Auth (min 16 chars)
AUTH_SECRET=replace-with-a-secure-random-string-at-least-32-chars

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
