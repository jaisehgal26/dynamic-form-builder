# Local Docker Postgres (port 5433 — see docker-compose.yml)
DATABASE_URL=postgresql://formforge:formforge@127.0.0.1:5433/formforge

AUTH_SECRET=replace-with-a-secure-random-string-at-least-32-chars
REDIS_URL=redis://127.0.0.1:6379
APP_ENV=development
REDIS_KEY_PREFIX=formforge:

# Production — Neon pooler URL (use in backend/.env, not .env.local)
# DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxx-pooler.c-4.us-east-2.aws.neon.tech/neondb?sslmode=require
# UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
# UPSTASH_REDIS_REST_TOKEN=
